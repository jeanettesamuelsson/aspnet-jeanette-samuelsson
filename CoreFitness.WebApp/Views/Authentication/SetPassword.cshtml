@model RegisterPasswordForm

@{
    Layout = "Layouts/_AuthLayout";
}

<section class="auth-section">
    <form class="auth-form" asp-action="SetPassword" asp-controller="Authentication" method="post" novalidate>
        <h1 class="title">Set Your Passowrd</h1>
        <p>
            Set a strong password to protect your account. 
            For security reasons, your password must be at least 8 characters 
            long and include uppercase and lowercase letters, numbers, and special 
            characters.
        </p>

        <hr />
       
        <div class="form-group">
            <label class="form-label" asp-for="Password"></label>
            <input class="input-label" asp-for="Password" />

            <span class="field-validation-error" asp-validation-for="Password"></span>

        </div>

        <div class="form-group">
            <label class="form-label" asp-for="ConfirmPassword"></label>
            <input class="input-label" asp-for="ConfirmPassword" />

            <span class="field-validation-error" asp-validation-for="ConfirmPassword"></span>

        </div>

        <button class="form-button" type="submit">Continue</button>

        @if (!string.IsNullOrWhiteSpace(ViewData["ErrorMessage"]?.ToString()))
            {
                <p class="additional-information">
                    @ViewData["ErrorMessage"]
                </p>
            }

    </form>
</section>