@using CoreFitness.WebApp.Models.CustomerService
@model ContactFormViewModel

<h1>Customer Service</h1>


<div id="customer-service-wrapper">

<img src="~/images/contact-us-image.svg"/> 

    <form class="auth-form" asp-action="Index" asp-controller="CustomerService" method="post" novalidate>
    
        <h1 class="title">Contact Us Today</h1>
        <p>Ready to begin your fitness journey? Contact GymPro today and let our expert trainers guide you with the right program and support.</p>

        <div class="form-row">
            <div class="form-group">
                <label class="form-label" asp-for="FirstName">First Name *</label>
                <input class="form-input" asp-for="FirstName" />
                <span class="field-validation-error" asp-validation-for="FirstName"></span>
            </div>
            <div class="form-group">
                <label class="form-label" asp-for="LastName">Last Name *</label>
                <input class="form-input" asp-for="LastName" />
                <span class="field-validation-error" asp-validation-for="LastName"></span>
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label class="form-label" asp-for="Email">Email Address *</label>
                <input class="form-input" asp-for="Email" />
                <span class="field-validation-error" asp-validation-for="Email"></span>
            </div>
            <div class="form-group">
                <label class="form-label" asp-for="PhoneNumber">Phone Number</label>
                <input class="form-input" asp-for="PhoneNumber" />
                <span class="field-validation-error" asp-validation-for="PhoneNumber"></span>
            </div>
        </div>

        <div class="form-group">
            <label class="form-label" asp-for="Message">Message *</label>
            <textarea class="text-input" asp-for="Message"></textarea>
            <span class="field-validation-error" asp-validation-for="Message"></span>
        </div>

      
        <button type="submit" class="signin-btn">
            <span>Submit Message</span>
            <i class="fa-solid fa-chevron-right"></i>
        </button>
    </form>


</div>

<div id="faq-section">

    <div id="faq-l-column">
    
        <img id="faq-img" src="~/images/faq.svg" />

    </div>

    <div id="faq-r-column">

        <span class="badge">Frequently Asked Questions</span>

        <h1>
            Common questions about
            gym and training
        </h1>

        <partial name="Partials/_FAQ" />

    </div>

</div>

