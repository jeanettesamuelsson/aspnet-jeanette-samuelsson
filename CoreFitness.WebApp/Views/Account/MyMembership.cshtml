@model MyMembershipViewModel


<h1>My Membership</h1>

<div class="about-section">
    <div class="about-l-column">

        <div class="menu-options">
            <div class="menu-header">Menu Options</div>
            <ul>
                <li>
                    <a asp-controller="Account" asp-action="My">
                        About Me <i class="fa-solid fa-chevron-right"></i>
                    </a>
                </li>

                <li>
                    <a asp-controller="Account" asp-action="MyMembership">
                        My Membership <i class="fa-solid fa-chevron-right"></i>
                    </a>
                </li>

                <li>
                    <a asp-controller="Account" asp-action="Bookings">
                        My Bookings <i class="fa-solid fa-chevron-right"></i>
                    </a>
                </li>

                <li>
                    <form asp-controller="Account" asp-action="Logout" method="post" id="logoutForm" style="display:inline;">
                        <a href="javascript:void(0)" onclick="document.getElementById('logoutForm').submit();">
                            Sign Out <i class="fa-solid fa-chevron-right"></i>
                        </a>
                    </form>
                </li>
            </ul>
        </div>


        <div class="remove-account-container">
            <p>If you would like to cancel your account, click below</p>

            <form asp-action="DeleteAccount" asp-controller="Account" method="post"
                  onsubmit="return confirm('Are you sure you want to delete your account? This cannot be undone.');">
                <button type="submit" class="btn-remove">
                    Remove Account
                </button>
            </form>
        </div>

    </div>

    <div class="about-r-column">

        <div class="my-membership">

                <h2>My Membership</h2>

            @if (Model.CurrentPlan != null)
            {
                <div class="current-membership-info">
                    <h4>Your current plan: @Model.CurrentPlan.Title</h4>
                    <p>Price: @Model.CurrentPlan.Price / month</p>
                </div>
            }
            else
            {
                <p>You don't have an active membership yet. Pick one below!</p>
            }
    
            <hr class="section-divider" />

            @* Form to update membership plan *@

            <div class="update-membership-box">

                <h3>Change or Select Plan</h3>

                <form asp-controller="Account" asp-action="UpdateMembershipPlan" method="post">

                    <div class="form-group">

                        <label for="membershipId">Available Memberships</label>
                        <select name="membershipId" id="membershipId" class="form-select" required>
                            <option value="">-- Select a new plan --</option>
                            @if (Model.AvailablePlans != null)
                            {
                                @foreach (var plan in Model.AvailablePlans)
                                {
                                    <option value="@plan.Id">@plan.Title (@plan.Price / month)</option>
                                }
                            }
                        </select>
                    </div>
                
                    <button type="submit" class="btn-update-plan">
                        Update Membership <i class="fa-solid fa-rotate"></i>
                    </button>

                </form>

            </div>
        </div>

    </div>

</div>

