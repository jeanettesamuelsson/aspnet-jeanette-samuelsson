@{
    ViewData["Title"] = "Home Page";
}

<section class="hero-section">
    <div class = "container-large">

         <div class="hero-content">
                 <div id="hero-left-column">
                      <h1>
                   Build Strength Boost
                   Confidence Today!
                  </h1>

             <p>
            Begin your fitness journey with expert trainers, modern equipment, and a
            supportive environment designed to help you build streangth and confidence.
              </p>

             <ul class="hero-features">
            <li>  <i class="fa-solid fa-check"> </i> Transform your body with training</li>
            <li>  <i class="fa-solid fa-check"> </i> Build confidence through fitness</li>
            <li>  <i class="fa-solid fa-check"> </i> Personal training for real results</li>
            <li>  <i class="fa-solid fa-check"> </i> Fitness tailored to your goals</li>
                </ul>

              <hr class="divider" />

              <a asp-controller="Membership" asp-action="Index" class="signin-btn">Get Started
                    <i class="fa-solid fa-chevron-right"></i>
                </a>
              

        </div>

              <div id="hero-right-column">
                 <img src="~/images/hero-right-column.svg" alt="Hero Image" />

              </div>
      </div>

  </div>

</section>

<section class="logo-banner">

    <div class="logo-container">
        <img src="~/images/brands.svg" alt="Brands" />
      

        <h2>Modern Equipment</h2>
</div>

</section>

<section class="about-us">
    <div class="container">
    <div class="about-wrapper">
        <div class="image-content">
            <img src="~/images/left-column.svg" alt="Våra tränare och träningsmiljö" class="about-image">
            </div>

            <div class="text-content">
                <span class="badge">About Us</span>
                <h2>Elevating Fitness Journey with Expert Guidance</h2>
                <p class="description">
                    We support every stage of your fitness journey with certified trainers,
                    personalized programs proven methods designed to help you train safely, build strength.
                </p>
            
                <div class="quote-card">
                    <p>Our mission is to transform lives by combining expert guidance, powerful training programs, and a motivating community that helps you grow stronger every day.</p>
                </div>
            </div>
        </div>
        </div>
    </section>

<section class="our-programs">
        <div class="container">
        <div class="program-content">
            <span class="badge">Our Programs</span>
            <h2>
                Professional training program
                for stronger health
            </h2>

            <div id ="program-img">
            <img src="~/images/program-image1.svg" alt="Alternate Text" />
            <img src="~/images/program-image2.svg" alt="Alternate Text" />
            <img src="~/images/program-image3.svg" alt="Alternate Text" />

            </div>
            
            <p>
                Let's make something great work together. <a href="#" >Get Free Quote </a>
            </p>
        </div>
        </div>

</section>

    <section class="our-store">
        <div class="container">
            <div class="store-content">
                <span class="badge">Our Store</span>
                <h2>
                    High quality fitness products
                    built for results
                </h2>

                <div id="program-img">
                    <img src="~/images/product-image-1.svg" alt="Alternate Text" />
                    <img src="~/images/product-image-2.svg" alt="Alternate Text" />
                    <img src="~/images/product-image-3.svg" alt="Alternate Text" />
                    <img src="~/images/product-image-4.svg" alt="Alternate Text" />

                </div>
            
                <p>
                    Let's make something great work together. <a href="#">Get Free Quote </a>
                </p>
            </div>
        </div>

    </section>
