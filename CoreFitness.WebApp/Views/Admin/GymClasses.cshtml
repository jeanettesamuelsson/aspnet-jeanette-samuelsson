@model IEnumerable<CoreFitness.Domain.Models.GymClass>

@* Använder domänmodellen här pga tidsbrist, kanske lägger in en viewmodel om tid finnes *@


<div class="admin-container">

    <div class="admin-header">
        <h1>Manage Gym Classes</h1>
        
    </div>

    @if (ViewData["ErrorMessage"] != null)
    {
        <div class="alert-danger">
            <i class="fa-solid fa-circle-exclamation"></i> @ViewData["ErrorMessage"]
        </div>
    }

    <div class="admin-top-actions">
        <a asp-action="CreateSession" class="signin-btn create-btn">
            <i class="fa-solid fa-plus"></i> Create New Class
        </a>
        <a asp-action="Index" class="back-link">
            <i class="fa-solid fa-arrow-left"></i> Back to Dashboard
        </a>
    </div>
    <div class="admin-top-actions">
        <a asp-action="CreateSession" class="signin-btn create-btn">
            <i class="fa-solid fa-plus"></i> Create New Class
        </a>
        <a asp-action="Index" class="back-link">
            <i class="fa-solid fa-arrow-left"></i> Back to Dashboard
        </a>
    </div>

    <div class="class-grid">
        @if (Model == null || !Model.Any())
        {
            <div class="empty-state">
                <p>No gym classes found in the database.</p>
            </div>
        }
        else
        {
            @foreach (var gymClass in Model)
            {
                <div class="class-card">
                    <div class="class-info">
                        <h3>@gymClass.Name</h3>
                        <p class="class-category"><strong>Category:</strong> @(gymClass.Category ?? "General")</p>
                        
                        <p class="class-time">
                            <i class="fa-regular fa-clock"></i> @gymClass.ScheduledTime.ToString("f")
                        </p>
                        
                        <p class="class-instructor">
                            <i class="fa-solid fa-user-tie"></i> Instructor: @(gymClass.Instructor ?? "TBA")
                        </p>

                        <p class="class-spots">
                            <i class="fa-solid fa-users"></i>
                            Capacity: @gymClass.Capacity
                        </p>
                    </div>
                    <div class="class-actions">
                        <button class="btn-small">Edit</button>
                        <button class="btn-small btn-delete">Delete</button>
                    </div>
                </div>
            }
        }
    </div>
</div>