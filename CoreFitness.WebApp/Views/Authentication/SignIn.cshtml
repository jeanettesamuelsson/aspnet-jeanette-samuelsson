@model SignInForm


@{
    Layout = "Layouts/_AuthLayout";
}

<section class="auth-section">

<form class ="auth-form" asp-action="SignIn" asp-controller="Authentication" method="post" novalidate>
   

    <h1 class="title">Welcome Back!</h1>
        <p>Log in to continue your fitness journey with full access to your customized program,
            training history, and progress tracking. Stay consistent, monitor your development,
            and keep moving forward with the structure and support built into your account.</p>

    <hr />

    <div class="login-icons">
    <img src="~/images/google.svg" alt="Icons" />
    <img src="~/images/facebook.svg" alt="Icons" />
    <img src="~/images/github.svg" alt="Icons" />

    </div>


    <hr />



    <div asp-validation-summary="ModelOnly"></div>

    <div class="form-group">
        <label class ="form-label" asp-for="Email">Enter Email Address</label>
        <input class="form-input" asp-for ="Email" />

        <span asp-validation-for="Email"></span>
    </div>

    <div class="form-group">
        <label class="form-label" asp-for="Password">Enter Password</label>
        <input class="form-input" asp-for="Password" />

        <span asp-validation-for="Password"></span>
    </div>

    

        <button type="submit" class ="signin-btn">
            <span>Sign In</span>
            <i class="fa-solid fa-chevron-right"></i>
        </button>
        

        @if (!string.IsNullOrWhiteSpace(ViewData["ErrorMessage"]?.ToString()))
            {
                <p class="additional-information">
                    @ViewData["ErrorMessage"]
                </p>

            }

            <p class="additional-information">
                Not a member yet? <a asp-action="SignUp" asp-controller="Authentication">Become one</a>
            </p>
</form>

</section>

